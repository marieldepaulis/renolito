# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ⚠️  NEVER expose this key to the browser or commit it to version control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
# Base URL used for server-side fetch calls (API routes calling themselves)
# In development: http://localhost:3000
# In production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (optional — for production outbound email) ─────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# FROM_EMAIL=no-reply@tudominio.com

# ─── Stripe (optional — for subscription billing) ────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
